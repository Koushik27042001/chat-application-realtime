PORT=5000
CLIENT_URL=
MONGODB_URI=

# Firebase Admin (use ONE of the two options below)
# Option A: Path to service account JSON (server-side only)
FIREBASE_SERVICE_ACCOUNT_PATH=backend/firebase-service-account.json

# Option B: Inline credentials (escape newlines in private key as \\n)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
