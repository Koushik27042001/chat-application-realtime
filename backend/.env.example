PORT=5000
CLIENT_URL=
MONGODB_URI=

# Firebase Admin — recommended for Render / production (no JSON file on disk)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# One line, real newlines as \n e.g. "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# Optional local only: path to JSON relative to project root — only used if file exists
# FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
