PORT=5000
CLIENT_URL=
MONGO_URI=
JWT_SECRET=

# After first user registers with this email, each server start assigns role admin
ADMIN_EMAIL=

# Optional: master admin login (POST /api/auth/admin-login) — NOT the user's normal password
# Set ADMIN_LOGIN_PASSWORD plus ONE of: ADMIN_LOGIN_USER_ID (Mongo _id) OR ADMIN_LOGIN_EMAIL
# ADMIN_LOGIN_USER_ID=507f1f77bcf86cd799439011
# ADMIN_LOGIN_EMAIL=admin@example.com
# ADMIN_LOGIN_PASSWORD=change-me-in-production

# Firebase Admin — recommended for Render / production (no JSON file on disk)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# One line, real newlines as \n e.g. "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# Optional local only: path to JSON relative to project root — only used if file exists
# FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
